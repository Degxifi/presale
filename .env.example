# $DEGX Presale — environment template. Copy to .env.local and fill in.
# NEXT_PUBLIC_* values are exposed to the browser. Never expose secrets.

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://presale.degxifi.com

# ---- Database (Supabase Postgres via Drizzle) ----
# Supabase dashboard → Connect → "Transaction pooler" URI (port 6543).
# Server-only: used at runtime AND by drizzle-kit (pnpm db:migrate). NEVER NEXT_PUBLIC_.
DATABASE_URL=postgresql://postgres.iutjzovhnsherjcdumlj:fAQiv57q.b6!3mt@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ---- Solana (mainnet only) ----
# SERVER-ONLY RPC with the provider key (Helius/QuickNode). NEVER prefix with
# NEXT_PUBLIC_ — that would expose the key in the browser bundle. The client
# talks to the same-origin /api/rpc proxy, which forwards to this.
SOLANA_RPC_URL=
# (Presale receiving wallet is HARDCODED in lib/solana/config.ts for security.)

# ---- Presale config ----
NEXT_PUBLIC_PRESALE_START=          # ISO 8601 start (admin-set). Timer end = start + 7 days

# ---- Admin auth (Better Auth) ----
# Roles live in the DB (user.role). The first registered user becomes the
# founding admin; promote/revoke others from the admin dashboard.
BETTER_AUTH_SECRET=                 # `openssl rand -base64 32` (server-only)
BETTER_AUTH_URL=http://localhost:3000   # set to the deployed origin in production

# ---- Rate limiting (Upstash Redis) ----
# Distributed limiter for the invest endpoint. Create a free Upstash Redis DB.
# Unset = limiter is a no-op (fine for local dev); REQUIRED in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Analytics (optional) ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Shared HMAC secret for members-only access links minted by the Degxifi backend
# (must equal the backend's PRESALE_ACCESS_SECRET; 32+ random chars). The gate
# fails CLOSED without it - the whole site shows /restricted.
PRESALE_ACCESS_SECRET=
